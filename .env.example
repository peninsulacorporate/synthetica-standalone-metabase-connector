# metabase-mcp-server — pick a mode by setting one variable group.

# ── Direct mode ────────────────────────────────────────────────────────
# Talk to a Metabase instance directly. Zero infrastructure.
METABASE_URL=https://metabase.example.com
METABASE_API_KEY=mb_replace_me

# ── Synthetica mode (Proxy Security Pattern) ───────────────────────────
# Set BACKEND_API_URL to switch into Synthetica mode automatically.
# In this mode the raw METABASE_API_KEY lives encrypted in the gateway —
# the MCP server only authenticates with SYNTHETICA_API_KEY.
# BACKEND_API_URL=https://gateway.yourcompany.com
# SYNTHETICA_API_KEY=sk_replace_me

# ── Server bind (both modes) ───────────────────────────────────────────
METABASE_MCP_HOST=0.0.0.0
METABASE_MCP_PORT=8092
LOG_LEVEL=INFO
